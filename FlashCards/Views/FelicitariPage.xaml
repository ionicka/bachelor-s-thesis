<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FlashCards.ViewModels"
             xmlns:dto="clr-namespace:FlashCards.Core.DTOs;assembly=FlashCards.Core"
             x:Class="FlashCards.Views.FelicitariPage"
             x:DataType="vm:FelicitariViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <Grid RowDefinitions="*,Auto" Padding="24">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20" Padding="0,32,0,0">

                <!-- Sectiunea sesiune — mereu vizibila -->
                <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                       CornerRadius="24" Padding="28">
                    <VerticalStackLayout Spacing="16">

                        <Label Text="{Binding EmojiSesiune}"
                               FontSize="72" HorizontalOptions="Center" />

                        <Label Text="{Binding TitluSesiune}"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Sesiune finalizata!"
                               FontSize="15" TextColor="#8899BB"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <!-- Statistici -->
                        <Grid ColumnDefinitions="*,*,*"
      Margin="0,8,0,0">

                            <VerticalStackLayout Grid.Column="0" Spacing="4"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                                <Label Text="{Binding NrCorect}"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#4CAF50"
               HorizontalTextAlignment="Center"
               HorizontalOptions="FillAndExpand" />
                                <Label Text="Corecte"
               FontSize="12"
               TextColor="#8899BB"
               HorizontalTextAlignment="Center"
               HorizontalOptions="FillAndExpand" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                                <Label Text="{Binding RataSucces, StringFormat='{}{0}%'}"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#FFD700"
               HorizontalTextAlignment="Center"
               HorizontalOptions="FillAndExpand" />
                                <Label Text="Rata"
               FontSize="12"
               TextColor="#8899BB"
               HorizontalTextAlignment="Center"
               HorizontalOptions="FillAndExpand" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Spacing="4"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                                <Label Text="{Binding NrGresit}"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#FF6B6B"
               HorizontalTextAlignment="Center"
               HorizontalOptions="FillAndExpand" />
                                <Label Text="Greșite"
               FontSize="12"
               TextColor="#8899BB"
               HorizontalTextAlignment="Center"
               HorizontalOptions="FillAndExpand" />
                            </VerticalStackLayout>

                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Sectiunea streak — doar prima sesiune a zilei -->
                <Frame IsVisible="{Binding AratStreak}"
                       BackgroundColor="#1A0A40" BorderColor="#7B2FBE"
                       CornerRadius="24" Padding="28">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="{Binding EmojiStreak}"
                               FontSize="56" HorizontalOptions="Center" />

                        <Label Text="{Binding TitluStreak}"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#FF6B35"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <Label Text="{Binding MesajStreak}"
                               FontSize="15" TextColor="#8899BB"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <Frame BackgroundColor="#2A1060" BorderColor="#9B5FDE"
                               CornerRadius="14" Padding="16,10"
                               HorizontalOptions="Center">
                            <Label Text="{Binding Streak, StringFormat='🔥 {0} zile consecutive'}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="#FF6B35"
                                   HorizontalOptions="Center" />
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <!-- Cuvinte invatate in aceasta sesiune -->
                <Frame IsVisible="{Binding AreCuvinte}"
                       BackgroundColor="#16213E" BorderColor="#0F3460"
                       CornerRadius="24" Padding="24">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="📝 Cuvinte recapitulate"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#8899BB"
                               HorizontalOptions="Center" />

                        <VerticalStackLayout
                            BindableLayout.ItemsSource="{Binding CuvinteInvatate}"
                            Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="dto:CuvantInvatat">
                                    <Frame BackgroundColor="#0F1A2E" BorderColor="#1A3060"
           CornerRadius="12" Padding="16,10">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                            <Label Grid.Row="0" Grid.Column="0"
                   Text="{Binding Termen}"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="White" />
                                            <Label Grid.Row="1" Grid.Column="0"
                   Text="{Binding Definitie}"
                   FontSize="13" TextColor="#8899BB"
                   LineBreakMode="TailTruncation" />
                                            <Frame Grid.Row="0" Grid.Column="1"
                   Grid.RowSpan="2"
                   BackgroundColor="#1A3060" BorderColor="#2E4A80"
                   CornerRadius="10" Padding="10,6"
                   VerticalOptions="Center">
                                                <VerticalStackLayout Spacing="0">
                                                    <Label Text="revizuire"
                           FontSize="10" TextColor="#8899BB"
                           HorizontalOptions="Center"/>
                                                    <Label Text="{Binding ZilePanaLaRevizuire}"
       FontSize="13" FontAttributes="Bold"
       TextColor="#4A90E2"
       HorizontalOptions="Center"/>
                                                </VerticalStackLayout>
                                            </Frame>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Cuvinte incomplete -->
                        <Frame IsVisible="{Binding AreIncomplete}"
       BackgroundColor="#16213E" BorderColor="#E94560"
       CornerRadius="24" Padding="24">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="⏳ Necesită mai multă practică"
               FontSize="16" FontAttributes="Bold"
               TextColor="#E94560"
               HorizontalOptions="Center" />
                                <VerticalStackLayout
            BindableLayout.ItemsSource="{Binding CuvinteIncomplete}"
            Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="dto:CuvantIncomplet">
                                            <Frame BackgroundColor="#0F1A2E" BorderColor="#E94560"
                           CornerRadius="12" Padding="16,10">
                                                <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Termen}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="White" />
                                                    <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Definitie}"
                                   FontSize="13" TextColor="#8899BB"
                                   LineBreakMode="TailTruncation" />
                                                    <Frame Grid.Row="0" Grid.Column="1"
                                   Grid.RowSpan="2"
                                   BackgroundColor="#2A0A0A"
                                   BorderColor="#E94560"
                                   CornerRadius="10" Padding="10,6"
                                   VerticalOptions="Center">
                                                        <VerticalStackLayout Spacing="0">
                                                            <Label Text="progres"
                                           FontSize="10" TextColor="#8899BB"
                                           HorizontalOptions="Center"/>
                                                            <Label Text="{Binding Progres, StringFormat='{0}%'}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="#E94560"
                                           HorizontalOptions="Center"/>
                                                        </VerticalStackLayout>
                                                    </Frame>
                                                </Grid>
                                            </Frame>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Butoane jos -->
        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0,12,0,20">
            <Button Text="Practica mai mult"
                    Clicked="OnPracticaClicked"
                    BackgroundColor="#16213E"
                    TextColor="#8899BB"
                    BorderColor="#2E3A5C" BorderWidth="1"
                    CornerRadius="16" HeightRequest="50"
                    FontSize="15" />
            <Button Text="Inapoi la meniu →"
                    Clicked="OnContinuaClicked"
                    BackgroundColor="#7B2FBE"
                    TextColor="White"
                    CornerRadius="16" HeightRequest="56"
                    FontSize="17" FontAttributes="Bold" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
