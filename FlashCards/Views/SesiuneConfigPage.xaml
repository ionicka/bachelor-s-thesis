<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FlashCards.ViewModels"
             xmlns:conv="clr-namespace:FlashCards.Converters"
             x:Class="FlashCards.Views.SesiuneConfigPage"
             x:DataType="vm:SesiuneConfigViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══════════════════════════════════════════ -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,44,16,16">
            <Button Grid.Column="0"
            Text="←"
            Command="{Binding InapoiCommand}"
            BackgroundColor="Transparent" TextColor="White"
            FontSize="22" WidthRequest="44" HeightRequest="44" Padding="0" />
            <Label Grid.Column="1"
           Text="Sesiune nouă"
           FontSize="20" FontAttributes="Bold" TextColor="White"
           VerticalOptions="Center" Margin="8,0,0,0" />
            <Frame Grid.Column="2"
           BackgroundColor="#1A1040"
           BorderColor="#7B2FBE"
           CornerRadius="14" Padding="0"
           HasShadow="False"
           VerticalOptions="Center">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ReseteazaToateFiltreCommand}" />
                </Frame.GestureRecognizers>
                <Label Text="↻ Reset"
               TextColor="#9B6FDE"
               FontSize="12" FontAttributes="Bold"
               Padding="12,8" VerticalOptions="Center" />
            </Frame>
        </Grid>
        <!-- ═══ CONȚINUT ═══════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" Padding="16,0,16,16">
            <VerticalStackLayout Spacing="18">

                <!-- ─── DISPONIBILITATE LIVE ─────────────────────── -->
                <Grid ColumnDefinitions="*,8,*,8,*" HeightRequest="110">
                    <Frame Grid.Column="0"
           BackgroundColor="#16213E"
           BorderColor="#E94560"
           CornerRadius="16"
           Padding="8"
           HasShadow="False">
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="🔄 De revizuit"
                   TextColor="#8899BB" FontSize="11"
                   HorizontalOptions="Center" />
                            <Label Text="{Binding NrRevizuiri}"
                   TextColor="#E94560" FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="2"
           BackgroundColor="#16213E"
           BorderColor="#4CAF50"
           CornerRadius="16"
           Padding="8"
           HasShadow="False">
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="✨ Noi"
                   TextColor="#8899BB" FontSize="11"
                   HorizontalOptions="Center" />
                            <Label Text="{Binding NrCuvinteNoi}"
                   TextColor="#4CAF50" FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="4"
       BackgroundColor="#16213E"
       BorderColor="#4A90E2"
       CornerRadius="16"
       Padding="8"
       HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MergeListaCarduriCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="📋"
               FontSize="20"
               HorizontalOptions="Center" />
                            <Label Text="Listă →"
               TextColor="#4A90E2"
               FontSize="13"
               FontAttributes="Bold"
               HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- ─── SELECTOR NR CARDURI ──────────────────────── -->
                <Frame BackgroundColor="#16213E"
       BorderColor="#7B2FBE"
       CornerRadius="16"
       Padding="20"
       HasShadow="False">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Selecteaza numarul de carduri?"
               TextColor="White" FontSize="14"
               FontAttributes="Bold" />

                        <Label Text="{Binding NrCarduriLabel}"
               TextColor="#9B6FDE" FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

                        <!-- Rândul 1: doar - și + cu numărul mare la mijloc -->
                        <Grid ColumnDefinitions="56,*,56" ColumnSpacing="12">
                            <Button Grid.Column="0"
                    Text="−"
                    Command="{Binding ScadeCarduriCommand}"
                    BackgroundColor="#2E1060"
                    TextColor="White"
                    FontSize="26"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="56"
                    Padding="0" />

                            <Frame Grid.Column="1"
                   BackgroundColor="#0F1A2E"
                   BorderColor="#7B2FBE"
                
                   CornerRadius="14"
                   Padding="0"
                   HasShadow="False">
                                <Label Text="{Binding NrCarduri}"
                       TextColor="White"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                            </Frame>

                            <Button Grid.Column="2"
                    Text="+"
                    Command="{Binding AdaugaCarduriCommand}"
                    BackgroundColor="#7B2FBE"
                    TextColor="White"
                    FontSize="26"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="56"
                    Padding="0" />
                        </Grid>

                        <!-- Rândul 2: preset-uri separate, mai aerisite -->
                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                            <Button Grid.Column="0" Text="5"
                    Command="{Binding SeteazaCarduriCommand}"
                    CommandParameter="5"
                    BackgroundColor="#1A1040"
                    TextColor="#9B6FDE"
                    BorderColor="#7B2FBE"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="42"
                    FontSize="13" />
                            <Button Grid.Column="1" Text="10"
                    Command="{Binding SeteazaCarduriCommand}"
                    CommandParameter="10"
                    BackgroundColor="#1A1040"
                    TextColor="#9B6FDE"
                    BorderColor="#7B2FBE"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="42"
                    FontSize="13" />
                            <Button Grid.Column="2" Text="15"
                    Command="{Binding SeteazaCarduriCommand}"
                    CommandParameter="15"
                    BackgroundColor="#1A1040"
                    TextColor="#9B6FDE"
                    BorderColor="#7B2FBE"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="42"
                    FontSize="13" />
                            <Button Grid.Column="3" Text="20"
                    Command="{Binding SeteazaCarduriCommand}"
                    CommandParameter="20"
                    BackgroundColor="#1A1040"
                    TextColor="#9B6FDE"
                    BorderColor="#7B2FBE"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="42"
                    FontSize="13" />
                            <Button Grid.Column="4" Text="30"
                    Command="{Binding SeteazaCarduriCommand}"
                    CommandParameter="30"
                    BackgroundColor="#1A1040"
                    TextColor="#9B6FDE"
                    BorderColor="#7B2FBE"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="42"
                    FontSize="13" />
                        </Grid>

                        <Label Text="Min 1, max 30 carduri per sesiune"
               TextColor="#556688" FontSize="11"
               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ─── FILTRU DIFICULTATE ───────────────────────── -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="📊 DIFICULTATE"
                               TextColor="#E94560"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="(nimic = toate)"
                               TextColor="#556688"
                               FontSize="10"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding NivelChips}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="6" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChipFiltruNivelVm">
                                <Frame BackgroundColor="{Binding BackgroundColor}"
                                       BorderColor="{Binding BorderColor}"
                                       CornerRadius="14"
                                       Padding="12,6"
                                       HasShadow="False">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                    </Frame.GestureRecognizers>
                                    <Label Text="{Binding Eticheta}"
                                           TextColor="{Binding TextColor}"
                                           FontSize="12"
                                           FontAttributes="Bold" />
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ─── FILTRU DOMENIU ───────────────────────────── -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="🎯 DOMENIU"
                               TextColor="#E94560"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="(nimic = toate)"
                               TextColor="#556688"
                               FontSize="10"
                               VerticalOptions="Center" />
                    </Grid>

                    <FlexLayout BindableLayout.ItemsSource="{Binding DomeniuChips}"
                                Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Start">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChipFiltruDomeniuVm">
                                <Frame BackgroundColor="{Binding BackgroundColor}"
                                       BorderColor="{Binding BorderColor}"
                                       CornerRadius="14"
                                       Padding="10,6"
                                       HasShadow="False"
                                       Margin="0,0,6,6">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                    </Frame.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="{Binding Icon}"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                        <Label Text="{Binding Eticheta}"
                                               TextColor="{Binding TextColor}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- ─── MOD ÎNVĂȚARE ─────────────────────────────── -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="🎓 MOD DE ÎNVĂȚARE"
           TextColor="#E94560"
           FontSize="11"
           FontAttributes="Bold"
           CharacterSpacing="1.5" />

                    <!-- 3 carduri orizontale -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                        <!-- Card 1: Toate -->
                        <Frame Grid.Column="0"
               BackgroundColor="{Binding ModToateBg}"
               BorderColor="#7B2FBE"
               CornerRadius="14"
               Padding="10"
               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeteazaModToateCommand}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="🎲" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Toate"
                       TextColor="{Binding ModToateText}"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                                <Label Text="Mix"
                       TextColor="{Binding ModToateText}"
                       FontSize="10"
                       HorizontalOptions="Center"
                       Opacity="0.7" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Card 2: Flashcards -->
                        <Frame Grid.Column="1"
               BackgroundColor="{Binding ModFlashcardsBg}"
               BorderColor="#4A90E2"
               CornerRadius="14"
               Padding="10"
               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeteazaModFlashcardsCommand}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="👁" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Flashcards"
                       TextColor="{Binding ModFlashcardsText}"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                                <Label Text="Vizual"
                       TextColor="{Binding ModFlashcardsText}"
                       FontSize="10"
                       HorizontalOptions="Center"
                       Opacity="0.7" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Card 3: Tastare -->
                        <Frame Grid.Column="2"
               BackgroundColor="{Binding ModTastareBg}"
               BorderColor="#E94560"
               CornerRadius="14"
               Padding="10"
               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeteazaModTastareCommand}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="⌨" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Tastare"
                       TextColor="{Binding ModTastareText}"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                                <Label Text="Activ"
                       TextColor="{Binding ModTastareText}"
                       FontSize="10"
                       HorizontalOptions="Center"
                       Opacity="0.7" />
                            </VerticalStackLayout>
                        </Frame>

                    </Grid>
                </VerticalStackLayout>

                <!-- ─── COMPOZIȚIA SESIUNII ─────────────────────── -->
                <Frame BackgroundColor="#1A1040"
                       BorderColor="#7B2FBE"
                       CornerRadius="16"
                       Padding="20"
                       HasShadow="False"
                       IsVisible="{Binding PoateIncepe}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📦 COMPOZIȚIA SESIUNII"
                               TextColor="#9B6FDE"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding RevizuiriInSesiune}"
                                       TextColor="#E94560"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                                <Label Text="Revizuiri"
                                       TextColor="#8899BB"
                                       FontSize="11"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding CuvinteNoiInSesiune}"
                                       TextColor="#4CAF50"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                                <Label Text="Cuvinte noi"
                                       TextColor="#8899BB"
                                       FontSize="11"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{Binding EstimareTimp}"
                               TextColor="#8899BB"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ─── MESAJ NIMIC DISPONIBIL ───────────────────── -->
                <Frame IsVisible="{Binding PoateIncepe,
                                    Converter={StaticResource InvertBool}}"
                       BackgroundColor="#1A0A0A"
                       BorderColor="#E94560"
                       CornerRadius="14"
                       Padding="16"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="⚠️ Niciun card disponibil"
                               TextColor="#E94560"
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Modifică filtrele sau apasă Reset."
                               TextColor="#8899BB"
                               FontSize="11"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <BoxView HeightRequest="20" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ BUTON START ═══════════════════════════════════════ -->
        <Button Grid.Row="2"
                Text="Începe sesiunea →"
                Command="{Binding InceptSesiuneCommand}"
                IsEnabled="{Binding PoateIncepe}"
                BackgroundColor="#7B2FBE"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="56"
                FontSize="17"
                FontAttributes="Bold"
                Margin="16,8,16,20">
            <Button.Triggers>
                <DataTrigger TargetType="Button"
                             Binding="{Binding PoateIncepe}"
                             Value="False">
                    <Setter Property="BackgroundColor" Value="#2E1060" />
                    <Setter Property="TextColor" Value="#556688" />
                </DataTrigger>
            </Button.Triggers>
        </Button>

    </Grid>
</ContentPage>