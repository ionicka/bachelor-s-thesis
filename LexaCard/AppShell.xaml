<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:LexaCard.Views"
       x:Class="LexaCard.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False">

    <!-- Login -->
    <ShellContent Route="LoginPage"
                  Shell.TabBarIsVisible="False"
                  Shell.NavBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- Pagina principala cu custom navbar jos -->
    <ShellContent Route="MainPage"
                  Shell.TabBarIsVisible="False"
                  Shell.NavBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:MainPage}" />

    <!-- Flux vocabular full screen TikTok -->
    <ShellContent Route="FluxPage"
                  Shell.TabBarIsVisible="False"
                  Shell.NavBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:FluxPage}" />

</Shell>
