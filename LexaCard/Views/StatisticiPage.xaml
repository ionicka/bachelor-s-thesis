<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LexaCard.ViewModels"
             xmlns:conv="clr-namespace:LexaCard.Converters"
             x:Class="LexaCard.Views.StatisticiPage"
             x:DataType="vm:StatisticiViewModel"
             Title="Statistici" BackgroundColor="#0D0D1A">

    <ContentPage.Resources>
        <conv:PercentToDoubleConverter x:Key="PercentToDouble" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Progresul tau" FontSize="24" FontAttributes="Bold"
                   TextColor="White" />

            <ActivityIndicator IsRunning="{Binding SeIncarca}"
                               IsVisible="{Binding SeIncarca}"
                               Color="#E94560" HorizontalOptions="Center" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12">

                <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="#16213E"
                       BorderColor="#0F3460" CornerRadius="16" Padding="20">
                    <VerticalStackLayout>
                        <Label Text="{Binding Statistici.CuvinteInvatate}"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="#4CAF50" HorizontalOptions="Center" />
                        <Label Text="Invatate" TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="#16213E"
                       BorderColor="#0F3460" CornerRadius="16" Padding="20">
                    <VerticalStackLayout>
                        <Label Text="{Binding Statistici.CuvinteConsolidate}"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="#FFD700" HorizontalOptions="Center" />
                        <Label Text="Consolidate" TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="#16213E"
                       BorderColor="#0F3460" CornerRadius="16" Padding="20">
                    <VerticalStackLayout>
                        <Label Text="{Binding Statistici.CuvinteDeRevizuitAzi}"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="#E94560" HorizontalOptions="Center" />
                        <Label Text="De revizuit" TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="#16213E"
                       BorderColor="#0F3460" CornerRadius="16" Padding="20">
                    <VerticalStackLayout>
                        <Label Text="{Binding Statistici.ZileCurenteStreak,
                                      StringFormat='{0} zile'}"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#FF8C00" HorizontalOptions="Center" />
                        <Label Text="Streak" TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                   CornerRadius="16" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Rata de succes" TextColor="#8899BB" FontSize="14" />
                    <ProgressBar
                        Progress="{Binding Statistici.RataSuccesGlobala,
                                   Converter={StaticResource PercentToDouble}}"
                        ProgressColor="#4CAF50" HeightRequest="12" />
                    <Label Text="{Binding Statistici.RataSuccesGlobala,
                                   StringFormat='{0:F1}%'}"
                           TextColor="White" FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
