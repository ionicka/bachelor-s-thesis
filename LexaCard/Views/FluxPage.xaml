<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LexaCard.ViewModels"
             xmlns:conv="clr-namespace:LexaCard.Converters"
             x:Class="LexaCard.Views.FluxPage"
             x:DataType="vm:FluxViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <ContentPage.Resources>
        <conv:InvertBoolConverter   x:Key="InvertBool" />
        <conv:StringToBoolConverter x:Key="StringToBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,16,20,8">
            <!-- Buton inapoi -->
            <Button Grid.Column="0"
                    Text="←"
                    Command="{Binding MergeInapoiCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="22"
                    WidthRequest="44"
                    HeightRequest="44"
                    Padding="0" />
            <Label Grid.Column="1" Text="LexaCard"
                   FontSize="18" FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="2"
                   Text="{Binding CardCurent.NivelCunoastere, StringFormat='Niv {0}/7'}"
                   TextColor="#8899BB" FontSize="13" VerticalOptions="Center" />
        </Grid>

        <!-- CONTINUT -->
        <Grid Grid.Row="1">

            <!-- Loader -->
            <VerticalStackLayout IsVisible="{Binding SeIncarca}"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="16">
                <ActivityIndicator IsRunning="True" Color="#E94560"
                                   WidthRequest="48" HeightRequest="48" />
                <Label Text="Se incarca..." TextColor="#8899BB" FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Sesiune goala -->
            <VerticalStackLayout IsVisible="{Binding SesiuneGoala}"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="20" Padding="32">
                <Label Text="🎉" FontSize="64" HorizontalOptions="Center" />
                <Label Text="Felicitari!" FontSize="28" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center" />
                <Label Text="Ai terminat toate cardurile pentru azi!"
                       FontSize="15" TextColor="#8899BB"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="40">
                    <VerticalStackLayout>
                        <Label Text="{Binding NrCorect}" FontSize="36"
                               FontAttributes="Bold" TextColor="#4CAF50"
                               HorizontalOptions="Center" />
                        <Label Text="Corecte" TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <VerticalStackLayout>
                        <Label Text="{Binding NrGresit}" FontSize="36"
                               FontAttributes="Bold" TextColor="#FF6B6B"
                               HorizontalOptions="Center" />
                        <Label Text="Gresite" TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Buton practica mai mult -->
                <Button Text="Practica mai mult"
                        Command="{Binding PracticaMailMultCommand}"
                        Style="{StaticResource BtnPrincipal}"
                        HeightRequest="52"
                        HorizontalOptions="Fill"
                        Margin="0,10,0,0" />

                <!-- Buton inapoi la meniu -->
                <Button Text="Inapoi la meniu"
                        Command="{Binding MergeInapoiCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#8899BB"
                        BorderColor="#2E3A5C"
                        BorderWidth="1"
                        CornerRadius="16"
                        HeightRequest="48"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>

            <!-- Cardul principal -->
            <ScrollView IsVisible="{Binding SesiuneGoala,
                                    Converter={StaticResource InvertBool}}"
                        Padding="16,4">
                <VerticalStackLayout Spacing="12">

                    <!-- Card termen -->
                    <Frame BackgroundColor="#16213E" CornerRadius="20"
                           Padding="0" BorderColor="#0F3460" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <SwipeGestureRecognizer Direction="Up"
                                Command="{Binding TreceLaUrmatorCardCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout>
                            <!-- Imagine -->
                            <Image HeightRequest="200" Aspect="AspectFill"
                                   IsVisible="{Binding CardCurent.CaleImagine,
                                               Converter={StaticResource StringToBool}}">
                                <Image.Source>
                                    <UriImageSource
                                        Uri="{Binding CardCurent.CaleImagine}"
                                        CachingEnabled="True"
                                        CacheValidity="1:00:00:00" />
                                </Image.Source>
                            </Image>
                            <!-- Termen -->
                            <VerticalStackLayout Padding="24,20" Spacing="8">

                                <!-- Inainte de revelatie: casute cu numarul de litere -->
                                <HorizontalStackLayout Spacing="5"
                                    IsVisible="{Binding PropozitieRevelata,
                                                Converter={StaticResource InvertBool}}"
                                    FlexLayout.Wrap="Wrap">
                                    <Label Text="{Binding CardCurent.CasuteLitere}"
                                           FontSize="38" FontAttributes="Bold"
                                           TextColor="White"
                                           CharacterSpacing="2"
                                           LineBreakMode="WordWrap" />
                                </HorizontalStackLayout>

                                <!-- Dupa revelatie: termenul real -->
                                <Label Text="{Binding CardCurent.Termen}"
                                       FontSize="42" FontAttributes="Bold"
                                       TextColor="White" LineBreakMode="WordWrap"
                                       IsVisible="{Binding PropozitieRevelata}" />

                                <!-- Pronuntie (doar dupa revelatie) -->
                                <Label Text="{Binding CardCurent.Pronuntie}"
                                       FontSize="16" TextColor="#8899BB"
                                       IsVisible="{Binding PropozitieRevelata}" />

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Definitie -->
                    <Frame BackgroundColor="#16213E" CornerRadius="16"
                           Padding="20" BorderColor="#0F3460">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="DEFINITIE" TextColor="#E94560"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1.5" />
                            <Label Text="{Binding CardCurent.Definitie}"
                                   TextColor="White" FontSize="16"
                                   LineHeight="1.5" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Propozitie -->
                    <Frame BackgroundColor="#16213E" CornerRadius="16"
                           Padding="20" BorderColor="#0F3460">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="EXEMPLU IN CONTEXT" TextColor="#E94560"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1.5" />
                            <Label Text="{Binding CardCurent.PropozitieBlur}"
                                   TextColor="#AABBCC" FontSize="16"
                                   FontAttributes="Italic" LineHeight="1.5"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding PropozitieRevelata,
                                               Converter={StaticResource InvertBool}}" />
                            <Label Text="{Binding CardCurent.PropozitieRevelata}"
                                   TextColor="#98FB98" FontSize="16"
                                   FontAttributes="Italic" LineHeight="1.5"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding PropozitieRevelata}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Tastare -->
                    <Frame BackgroundColor="#16213E" CornerRadius="16"
                           Padding="20" BorderColor="#E94560"
                           IsVisible="{Binding ModTastare}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="TASTEAZA CUVANTUL" TextColor="#E94560"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1.5" />
                            <Entry Text="{Binding TextTastat}"
                                   Placeholder="Scrie cuvantul aici..."
                                   BackgroundColor="#0F3460" TextColor="White"
                                   PlaceholderColor="#556688" FontSize="16"
                                   ReturnCommand="{Binding RaspundeTastareCommand}" />
                            <Button Text="Verifica raspunsul"
                                    Command="{Binding RaspundeTastareCommand}"
                                    BackgroundColor="#E94560" TextColor="White"
                                    CornerRadius="12" HeightRequest="50"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="80" BackgroundColor="Transparent" />

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- BUTOANE JOS -->
        <Grid Grid.Row="2"
              IsVisible="{Binding SesiuneGoala, Converter={StaticResource InvertBool}}"
              Padding="16,8,16,24" BackgroundColor="#0D0D1A">

            <!-- Inainte de revelatie -->
            <Button Text="Reveleaza propozitia"
                    Command="{Binding RevelazaPropozitiaCommand}"
                    IsVisible="{Binding PropozitieRevelata,
                                Converter={StaticResource InvertBool}}"
                    Style="{StaticResource BtnDark}"
                    HeightRequest="56" />

            <!-- Dupa revelatie -->
            <Grid IsVisible="{Binding PropozitieRevelata}"
                  RowDefinitions="Auto,Auto" RowSpacing="10">

                <Grid Grid.Row="0" ColumnDefinitions="*,12,*" HeightRequest="56">
                    <Button Grid.Column="0" Text="Nu stiu"
                            Command="{Binding RaspundeRecunoastereCommand}"
                            CommandParameter="nu"
                            Style="{StaticResource BtnRosu}" />
                    <Button Grid.Column="2" Text="Stiu!"
                            Command="{Binding RaspundeRecunoastereCommand}"
                            CommandParameter="sigur"
                            Style="{StaticResource BtnVerde}" />
                </Grid>

                <Button Grid.Row="1" Text="Stiu, dar cu ezitare"
                        Command="{Binding RaspundeRecunoastereCommand}"
                        CommandParameter="ezitare"
                        Style="{StaticResource BtnAlbastru}"
                        HeightRequest="46" />
            </Grid>

        </Grid>

    </Grid>
</ContentPage>
