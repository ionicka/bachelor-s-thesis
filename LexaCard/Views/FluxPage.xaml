<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LexaCard.ViewModels"
             xmlns:conv="clr-namespace:LexaCard.Converters"
             x:Class="LexaCard.Views.FluxPage"
             x:DataType="vm:FluxViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <ContentPage.Resources>
        <conv:InvertBoolConverter   x:Key="InvertBool" />
        <conv:StringToBoolConverter x:Key="StringToBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,16,20,8">
            <Button Grid.Column="0"
                    Text="←"
                    Command="{Binding MergeInapoiCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="22"
                    WidthRequest="44"
                    HeightRequest="44"
                    Padding="0" />
            <Label Grid.Column="1" Text="LexaCard"
                   FontSize="18" FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="2"
                   Text="{Binding ProgressText}"
                   TextColor="#8899BB" FontSize="13" VerticalOptions="Center" />
        </Grid>

        <!-- CONTINUT -->
        <Grid Grid.Row="1">

            <!-- Loader -->
            <VerticalStackLayout IsVisible="{Binding SeIncarca}"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="16">
                <ActivityIndicator IsRunning="True" Color="#E94560"
                                   WidthRequest="48" HeightRequest="48" />
                <Label Text="Se incarca..." TextColor="#8899BB" FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Sesiune goala - pagina FelicitariPage se deschide din code-behind -->
            <ActivityIndicator IsVisible="{Binding SesiuneGoala}"
                               IsRunning="{Binding SesiuneGoala}"
                               Color="#7B2FBE"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />

            <!-- Cardul principal -->
            <ScrollView IsVisible="{Binding SesiuneGoala,
                                    Converter={StaticResource InvertBool}}"
                        Padding="16,4">
                <VerticalStackLayout Spacing="12">

                    <!-- IMAGINI - dispare complet daca CaleImagini e null -->
                    <Grid IsVisible="{Binding AreImagini}">
                        <Image Source="{Binding ImagineCurenta}"
                               Aspect="AspectFit"
                               HeightRequest="200"
                               BackgroundColor="#0F1A2E" />
                        <Button Text="⇄"
                                Command="{Binding SchimbaImagineCommand}"
                                IsVisible="{Binding AreDuaImagini}"
                                BackgroundColor="#80000000"
                                TextColor="White" FontSize="18"
                                WidthRequest="40" HeightRequest="40"
                                CornerRadius="20" Padding="0"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                Margin="0,0,10,10" />
                    </Grid>

                    <!-- TERMEN -->
                    <Frame BackgroundColor="#0F1A2E" CornerRadius="16"
                           Padding="20,16" BorderColor="Transparent">
                        <VerticalStackLayout Spacing="6">
                            <!-- Inainte de revelatie: casute -->
                            <Label Text="{Binding CardCurent.CasuteLitere}"
                                   FontSize="36" FontAttributes="Bold"
                                   TextColor="White" CharacterSpacing="4"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding PropozitieRevelata,
                                               Converter={StaticResource InvertBool}}" />
                            <!-- Dupa revelatie: termenul + buton pronuntie -->
                            <Grid IsVisible="{Binding PropozitieRevelata}"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding CardCurent.Termen}"
                                       FontSize="38" FontAttributes="Bold"
                                       TextColor="White" LineBreakMode="WordWrap"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="🔊"
                                        Command="{Binding PronuntaCuvantCommand}"
                                        BackgroundColor="Transparent"
                                        FontSize="22"
                                        WidthRequest="48" HeightRequest="48"
                                        Padding="0" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="{Binding CardCurent.Pronuntie}"
                                   FontSize="15" TextColor="#8899BB"
                                   IsVisible="{Binding PropozitieRevelata}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- DEFINITIE cu buton traducere -->
                    <Frame BackgroundColor="#16213E" CornerRadius="16"
                           Padding="20" BorderColor="#0F3460">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="DEFINITIE" TextColor="#E94560"
                                       FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="{Binding BtnTradLabel}"
                                        Command="{Binding ToggleTraducereCommand}"
                                        BackgroundColor="#1A3060"
                                        TextColor="#8899BB"
                                        FontSize="11" FontAttributes="Bold"
                                        CornerRadius="8"
                                        HeightRequest="28" Padding="8,0" />
                            </Grid>
                            <Label Text="{Binding DefinitieAfisata}"
                                   TextColor="White" FontSize="15"
                                   LineHeight="1.5" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- EXEMPLE cu buton swap -->
                    <Frame BackgroundColor="#16213E" CornerRadius="16"
                           Padding="20" BorderColor="#0F3460">
                        <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="EXEMPLU IN CONTEXT"
                                       TextColor="#E94560" FontSize="11"
                                       FontAttributes="Bold" CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                                <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                    <Button Text="🔊"
                                            Command="{Binding PronuntaExempluCommand}"
                                            IsVisible="{Binding PropozitieRevelata}"
                                            BackgroundColor="Transparent"
                                            FontSize="16"
                                            WidthRequest="36" HeightRequest="28"
                                            Padding="0" />
                                    <Button Text="→"
                                            Command="{Binding SchimbaExempluCommand}"
                                            BackgroundColor="#1A3060"
                                            TextColor="#8899BB" FontSize="14"
                                            CornerRadius="8"
                                            HeightRequest="28" Padding="8,0" />
                                </StackLayout>
                            </Grid>
                            <!-- Blur (inainte de revelatie) -->
                            <Label Text="{Binding ExempluCurentBlur}"
                                   TextColor="#AABBCC" FontSize="15"
                                   FontAttributes="Italic" LineHeight="1.5"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding PropozitieRevelata,
                                               Converter={StaticResource InvertBool}}" />
                            <!-- Revelat cu cuvantul bold+colorat -->
                            <Label FontSize="15" FontAttributes="Italic"
                                   LineHeight="1.5" LineBreakMode="WordWrap"
                                   IsVisible="{Binding PropozitieRevelata}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding ExempluParti.Inainte}"
                                              TextColor="#AABBCC" />
                                        <Span Text="{Binding ExempluParti.Cuvant}"
                                              TextColor="#FFD700"
                                              FontAttributes="Bold"
                                              FontSize="16" />
                                        <Span Text="{Binding ExempluParti.Dupa}"
                                              TextColor="#AABBCC" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Tastare -->
                    <Frame BackgroundColor="#16213E" CornerRadius="16"
                           Padding="20" BorderColor="#E94560"
                           IsVisible="{Binding ModTastare}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="TASTEAZA CUVANTUL" TextColor="#E94560"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1.5" />
                            <Entry Text="{Binding TextTastat}"
                                   Placeholder="Scrie cuvantul aici..."
                                   BackgroundColor="#0F3460" TextColor="White"
                                   PlaceholderColor="#556688" FontSize="16"
                                   ReturnCommand="{Binding RaspundeTastareCommand}"
                                   IsEnabled="{Binding AsteaptaMailDeparte,
                                               Converter={StaticResource InvertBool}}" />
                            <Button Text="Verifica raspunsul"
                                    Command="{Binding RaspundeTastareCommand}"
                                    IsEnabled="{Binding AsteaptaMailDeparte,
                                                Converter={StaticResource InvertBool}}"
                                    BackgroundColor="#E94560" TextColor="White"
                                    CornerRadius="12" HeightRequest="50"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="80" BackgroundColor="Transparent" />

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- FEEDBACK BAR -->
        <Frame Grid.Row="2"
               BackgroundColor="{Binding ColorFeedback}"
               BorderColor="Transparent"
               CornerRadius="0" Padding="16,10"
               IsVisible="{Binding MesajFeedback,
                           Converter={StaticResource StringToBool}}"
               HeightRequest="48">
            <Label Text="{Binding MesajFeedback}"
                   TextColor="White" FontSize="16"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Frame>


        <!-- BUTOANE JOS -->
        <Grid Grid.Row="2"
              IsVisible="{Binding SesiuneGoala, Converter={StaticResource InvertBool}}"
              Padding="16,8,16,24" BackgroundColor="#0D0D1A"
              RowDefinitions="Auto,Auto" RowSpacing="8">

            <!-- Feedback -->
            <Frame Grid.Row="0"
                   BackgroundColor="{Binding ColorFeedback}"
                   BorderColor="Transparent"
                   CornerRadius="12" Padding="12,8"
                   IsVisible="{Binding MesajFeedback,
                               Converter={StaticResource StringToBool}}">
                <Label Text="{Binding MesajFeedback}"
                       TextColor="White" FontSize="15"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </Frame>

            <Grid Grid.Row="1">

                <!-- MAI DEPARTE — deasupra tuturor, apare dupa raspuns -->
                <Button Text="Mai departe →"
                        Command="{Binding MailDeparteCommand}"
                        IsVisible="{Binding AsteaptaMailDeparte}"
                        BackgroundColor="#2E5A8C"
                        TextColor="White"
                        CornerRadius="16"
                        HeightRequest="56"
                        FontSize="16"
                        FontAttributes="Bold" />

                <!-- Toate butoanele normale — dispar dupa raspuns -->
                <Grid IsVisible="{Binding AsteaptaMailDeparte,
                                  Converter={StaticResource InvertBool}}"
                      RowDefinitions="Auto,Auto" RowSpacing="8">

                    <!-- TASTARE -->
                    <Button Grid.Row="0"
                            Text="Verifica raspunsul"
                            Command="{Binding RaspundeTastareCommand}"
                            IsVisible="{Binding ModTastare}"
                            IsEnabled="{Binding AsteaptaMailDeparte,
                                        Converter={StaticResource InvertBool}}"
                            Style="{StaticResource BtnPrincipal}"
                            HeightRequest="56" />

                    <!-- RECUNOASTERE -->
                    <Grid Grid.Row="0"
                          IsVisible="{Binding ModTastare,
                                      Converter={StaticResource InvertBool}}"
                          RowDefinitions="Auto,Auto" RowSpacing="8">

                        <!-- Inainte de revelatie -->
                        <Button Grid.Row="0"
                                Text="Reveleaza propozitia"
                                Command="{Binding RevelazaPropozitiaCommand}"
                                IsVisible="{Binding PropozitieRevelata,
                                            Converter={StaticResource InvertBool}}"
                                Style="{StaticResource BtnDark}"
                                HeightRequest="56" />

                        <!-- Dupa revelatie -->
                        <Grid Grid.Row="1"
                              IsVisible="{Binding PropozitieRevelata}"
                              RowDefinitions="Auto,Auto" RowSpacing="8">

                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,10,*" HeightRequest="56">
                                <Button Grid.Column="0"
                                        Text="Nu stiu"
                                        Command="{Binding RaspundeRecunoastereCommand}"
                                        CommandParameter="nu"
                                        Style="{StaticResource BtnRosu}" />
                                <Button Grid.Column="2"
                                        Text="Stiu!"
                                        Command="{Binding RaspundeRecunoastereCommand}"
                                        CommandParameter="sigur"
                                        Style="{StaticResource BtnVerde}" />
                            </Grid>

                            <Button Grid.Row="1"
                                    Text="Stiu, dar cu ezitare"
                                    Command="{Binding RaspundeRecunoastereCommand}"
                                    CommandParameter="ezitare"
                                    Style="{StaticResource BtnAlbastru}"
                                    HeightRequest="46" />
                        </Grid>
                    </Grid>

                </Grid>

            </Grid>

        </Grid>

    </Grid>
</ContentPage>
