<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LexaCard.ViewModels"
             xmlns:conv="clr-namespace:LexaCard.Converters"
             x:Class="LexaCard.Views.SesiuneConfigPage"
             x:DataType="vm:SesiuneConfigViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="0,44,0,16">
            <Button Grid.Column="0" Text="←"
                    Command="{Binding InapoiCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White" FontSize="22"
                    WidthRequest="44" HeightRequest="44" Padding="0"
                    HorizontalOptions="Start" />
            <Label Grid.Column="1" Text="Sesiune noua"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White" VerticalOptions="Center"
                   HorizontalOptions="Start" Margin="12,0,0,0" />
        </Grid>

        <!-- Continut -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14">

                <!-- Revizuiri de azi -->
                <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                       CornerRadius="16" Padding="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="De revizuit azi"
                                   TextColor="#8899BB" FontSize="13"
                                   HorizontalOptions="Start" />
                            <Label Text="{Binding NrRevizuiri, StringFormat='{0} cuvinte'}"
                                   TextColor="#E94560" FontSize="24"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Start" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="🔄" FontSize="36"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Cuvinte noi disponibile -->
                <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                       CornerRadius="16" Padding="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Cuvinte noi disponibile"
                                   TextColor="#8899BB" FontSize="13"
                                   HorizontalOptions="Start" />
                            <Label Text="{Binding NrCuvinteNoi, StringFormat='{0} cuvinte'}"
                                   TextColor="#4CAF50" FontSize="24"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Start" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="✨" FontSize="36"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Configurare cuvinte noi -->
                <Frame BackgroundColor="#16213E" BorderColor="#7B2FBE"
                       CornerRadius="16" Padding="20">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Cate cuvinte noi vrei azi?"
                               TextColor="White" FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Start" />

                        <!-- Numarul de cuvinte selectate - INT fara zecimale -->
                        <Label Text="{Binding CuvinteNoi, StringFormat='{0} cuvinte noi'}"
                               TextColor="#9B6FDE" FontSize="30"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />

                        <!-- Slider legat la SliderVal (double intern) -->
                        <Slider Minimum="0"
                                Maximum="{Binding MaxCuvinteNoi}"
                                Value="{Binding SliderVal, Mode=TwoWay}"
                                ThumbColor="#7B2FBE"
                                MinimumTrackColor="#7B2FBE"
                                MaximumTrackColor="#2E3A5C" />

                        <!-- Butoane rapide -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="5"
                                    Command="{Binding SeteazaCuvinteCommand}"
                                    CommandParameter="5"
                                    BackgroundColor="#1A1040" TextColor="#9B6FDE"
                                    BorderColor="#7B2FBE" BorderWidth="1"
                                    CornerRadius="10" HeightRequest="44" />
                            <Button Grid.Column="1" Text="10"
                                    Command="{Binding SeteazaCuvinteCommand}"
                                    CommandParameter="10"
                                    BackgroundColor="#1A1040" TextColor="#9B6FDE"
                                    BorderColor="#7B2FBE" BorderWidth="1"
                                    CornerRadius="10" HeightRequest="44" />
                            <Button Grid.Column="2" Text="20"
                                    Command="{Binding SeteazaCuvinteCommand}"
                                    CommandParameter="20"
                                    BackgroundColor="#1A1040" TextColor="#9B6FDE"
                                    BorderColor="#7B2FBE" BorderWidth="1"
                                    CornerRadius="10" HeightRequest="44" />
                            <Button Grid.Column="3" Text="50"
                                    Command="{Binding SeteazaCuvinteCommand}"
                                    CommandParameter="50"
                                    BackgroundColor="#1A1040" TextColor="#9B6FDE"
                                    BorderColor="#7B2FBE" BorderWidth="1"
                                    CornerRadius="10" HeightRequest="44" />
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Rezumat sesiune -->
                <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                       CornerRadius="16" Padding="20">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Rezumat sesiune"
                               TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Start" />
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="{Binding TotalSesiune}"
                                   FontAttributes="Bold" FontSize="24"
                                   TextColor="#E94560" />
                            <Label Text="carduri totale"
                                   TextColor="White" FontSize="16"
                                   VerticalOptions="End" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding EstimareTimp}"
                               TextColor="#8899BB" FontSize="13"
                               HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Buton Start -->
        <Button Grid.Row="2"
                Text="Incepe sesiunea"
                Command="{Binding InceptSesiuneCommand}"
                BackgroundColor="#7B2FBE"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="58"
                FontSize="18"
                FontAttributes="Bold"
                Margin="0,12,0,28" />

    </Grid>
</ContentPage>
